# Credentials — the ARS app reads these directly (no ant auth / no manual key paste
# needed when generated from an active cc-switch session).
#
# Option A (relay via cc-switch, e.g. sharkapi): use a bearer token + custom base URL
ANTHROPIC_AUTH_TOKEN=sk-xxxxxxxx
ANTHROPIC_BASE_URL=https://api.sharkapi.cc/
#
# Option B (official Anthropic API): set a real key instead, leave BASE_URL unset
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# Model + effort
ARS_MODEL=claude-opus-4-8
ARS_EFFORT=medium

# Feature flags — auto-tuned by `npm run check` against your endpoint.
# 1 = enabled, 0 = disabled (ClaudeClient degrades gracefully when off).
ARS_THINKING=1
ARS_EFFORT_PARAM=1
ARS_STRUCTURED=1
ARS_STREAM=1

# Optional: Semantic Scholar API key (higher rate limits; works without one)
SEMANTIC_SCHOLAR_API_KEY=

# ============================================================================
# Paid layer (accounts + credits + payments). One codebase, two deployments:
# domestic (Alipay/CNY) and international (Stripe/USD) differ only by these vars.
# ============================================================================

# Where the SQLite database lives. MUST be on a persistent disk in production
# (Render Disk / Docker volume) or a redeploy wipes users & credits.
DATABASE_PATH=./data/ars.db

# Secret used to sign the session cookie. Set a long random value in production.
SESSION_SECRET=change-me-to-a-long-random-string
# Session lifetime in days (default 30).
SESSION_TTL_DAYS=30
# Set to 1 when serving over HTTPS so the cookie is marked Secure (auto-on if
# PUBLIC_BASE_URL is https).
COOKIE_SECURE=0

# Credit economy.
SIGNUP_BONUS_CREDITS=20   # free credits granted on signup
RUN_COST_CREDITS=10       # credits charged per research run (refunded on failure)
REQUIRE_EMAIL_VERIFY=0    # 1 to require email verification before use (M1: off)

# Public URL of this deployment — used to build payment return/redirect URLs.
PUBLIC_BASE_URL=http://localhost:5173

# Which payment channel is live: mock | stripe | alipay
PAYMENT_PROVIDER=mock
# Currency of the shown price list: USD (international) | CNY (domestic)
SITE_CURRENCY=USD

# --- Stripe (international site) ---
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx      # from `stripe listen` or the dashboard

# --- Alipay (domestic site — reserved, see billing/alipay.ts) ---
# ALIPAY_APP_ID=
# ALIPAY_PRIVATE_KEY=
# ALIPAY_PUBLIC_KEY=
